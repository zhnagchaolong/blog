---
import { homepage } from '@/config/site';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

{projects.length > 0 && (
  <section class="animate-fade-up">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-sans text-fluid-lg font-semibold text-text-primary tracking-tight">{homepage.sections.featuredProjectsTitle}</h2>
      <a href={import.meta.env.BASE_URL + '/projects'} class="font-sans text-base text-text-secondary hover:text-accent transition-colors duration-200">{homepage.sections.viewAllText}</a>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {projects.map(project => (
        <article class="group">
          <a
            href={project.data.link || '#'}
            target={project.data.link ? '_blank' : undefined}
            rel={project.data.link ? 'noopener noreferrer' : undefined}
            class="block h-full p-5 rounded-sm bg-surface border border-border/40 hover:border-border transition-colors duration-200"
          >
            <h3 class="font-sans text-base font-semibold text-text-primary group-hover:text-accent transition-colors duration-200 mb-1.5 tracking-tight">
              {project.data.title}
            </h3>

            <p class="font-sans text-base text-text-secondary/80 line-clamp-2 leading-relaxed mb-4">
              {project.data.description}
            </p>

            <div class="flex flex-wrap gap-1.5">
              {project.data.techStack.map(tech => (
                <span class="px-2 py-0.5 rounded text-xs font-mono text-text-muted bg-elevated">
                  {tech}
                </span>
              ))}
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
)}
