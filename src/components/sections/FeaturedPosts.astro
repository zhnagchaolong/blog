---
import { formatDate } from '@/utils/date';
import { categoryLabels } from '@/config/labels';
import { homepage } from '@/config/site';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="mb-20 animate-fade-up">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-sans text-fluid-lg font-semibold text-text-primary tracking-tight">{homepage.sections.featuredPostsTitle}</h2>
      <a href="/posts" class="font-sans text-base text-text-secondary hover:text-accent transition-colors duration-200">{homepage.sections.viewAllText}</a>
    </div>

    <div class="divide-y divide-border/60">
      {posts.map(post => (
        <article class="py-5 group">
          <a href={`/posts/${post.slug}/`} class="block">
            <h3 class="font-sans text-lg font-medium text-text-primary group-hover:text-accent transition-colors duration-200 mb-1.5 tracking-tight leading-snug">
              {post.data.title}
            </h3>

            <p class="font-sans text-base text-text-secondary/80 line-clamp-2 leading-relaxed mb-2">
              {post.data.description}
            </p>

            <div class="flex items-center gap-2 text-xs text-text-muted font-mono">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              {post.data.category && (
                <>
                  <span>·</span>
                  <span>{categoryLabels[post.data.category] || post.data.category}</span>
                </>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
)}
