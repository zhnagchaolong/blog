---
import { ariaLabels } from '@/config/site';
---

<button
  id="scroll-to-top"
  class="fixed bottom-8 right-6 z-40 w-10 h-10 rounded-full bg-surface border border-border text-text-muted hover:text-accent hover:border-accent/30 transition-all duration-300 opacity-0 translate-y-2 pointer-events-none hidden md:flex items-center justify-center shadow-sm"
  aria-label={ariaLabels.scrollToTop}
  title={ariaLabels.scrollToTop}
>
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
</button>

<script>
  (function() {
    let visible = false;

    function getBtn() {
      return document.getElementById('scroll-to-top');
    }

    function toggle() {
      const btn = getBtn();
      if (!btn) return;
      const shouldShow = window.scrollY > window.innerHeight * 0.6;
      if (shouldShow && !visible) {
        btn.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
        visible = true;
      } else if (!shouldShow && visible) {
        btn.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
        visible = false;
      }
    }

    window.addEventListener('scroll', () => {
      requestAnimationFrame(toggle);
    }, { passive: true });

    document.addEventListener('click', function(e) {
      const target = e.target as HTMLElement;
      if (target.closest('#scroll-to-top')) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    // View Transitions 后重置状态
    document.addEventListener('astro:after-swap', function() {
      visible = false;
    });
  })();
</script>
