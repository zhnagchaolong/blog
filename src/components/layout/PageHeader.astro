---
interface Props {
  label: string;
  title: string;
  subtitle?: string;
}

const { label, title, subtitle } = Astro.props;
---

<header class="pt-[16vh] pb-16">
  <span class="font-mono text-xs tracking-[0.2em] text-text-muted/40 uppercase block mb-4">
    {label}
  </span>
  <h1 class="font-sans text-4xl font-light text-text-primary tracking-[0.05em]">
    {title}
  </h1>
  {subtitle && (
    <p class="font-sans text-base text-text-secondary mt-5 leading-relaxed max-w-md">
      {subtitle}
    </p>
  )}
</header>
