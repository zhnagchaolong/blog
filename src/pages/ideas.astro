---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/layout/PageHeader.astro';
import BackLink from '@/components/layout/BackLink.astro';
import { categoryMeta } from '@/config/labels';
import { pageMeta } from '@/config/site';

const posts = await getCollection('posts', ({ data }) => !data.draft);

// 按 category 分组统计
const categoryMap = new Map<string, typeof posts>();
posts.forEach(post => {
  const cat = post.data.category;
  if (!categoryMap.has(cat)) categoryMap.set(cat, []);
  categoryMap.get(cat)!.push(post);
});

// 保持固定顺序
const categories = ['tech', 'design', 'philosophy', 'essay'].filter(c => categoryMap.has(c));
---

<Base title={pageMeta.ideas.title} description={pageMeta.ideas.description}>
  <div class="max-w-prose-lg mx-auto">
    <BackLink />

    <PageHeader
      label={`${pageMeta.ideas.labelPrefix} / ${String(posts.length).padStart(3, '0')}`}
      title={pageMeta.ideas.heading}
      subtitle={pageMeta.ideas.subtitle.replace('{count}', String(categories.length)).replace('{total}', String(posts.length))}
    />

    <div class="grid gap-6 animate-fade-up">
      {categories.map(cat => {
        const catPosts = categoryMap.get(cat)!;
        const meta = categoryMeta[cat];
        const latest = catPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];
        return (
          <a
            href={`/posts`}
            class="group block p-8 rounded-md bg-surface border border-border/50 transition-all duration-300 ease-[cubic-bezier(0.23,1,0.32,1)] hover:border-accent/20"
          >
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <h2 class="font-sans text-2xl font-bold text-text-primary group-hover:text-accent transition-colors duration-300 tracking-tight">
                  {meta.label}
                </h2>
                <p class="font-sans text-base text-text-secondary mt-2 leading-relaxed">
                  {meta.description}
                </p>
              </div>
              <span class="font-mono text-sm text-text-muted/50 shrink-0 mt-1">
                {String(catPosts.length).padStart(2, '0')} 篇              </span>
            </div>

            {/* 最近更新 */}
            <div class="pt-4 border-t border-border/40 flex items-center justify-between">
              <span class="font-mono text-xs text-text-muted/40 uppercase tracking-wider">最近更新</span>
              <span class="font-sans text-base text-text-secondary group-hover:text-accent transition-colors duration-300 truncate max-w-[60%]">
                {latest.data.title}
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Base>
