---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/layout/PageHeader.astro';
import { pageMeta, projectLabels } from '@/config/site';
import BackLink from '@/components/layout/BackLink.astro';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
---

<Base title={pageMeta.projects.title} description={pageMeta.projects.description}>
  <div class="max-w-prose-lg mx-auto">
    <BackLink />

    <PageHeader
      label={`${pageMeta.projects.labelPrefix} / ${String(projects.length).padStart(3, '0')}`}
      title={pageMeta.projects.heading}
      subtitle={pageMeta.projects.subtitle}
    />
    
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map(project => (
        <article class="group p-6 rounded-md border border-border hover:border-accent/30 bg-surface hover:bg-elevated transition-all duration-300 flex flex-col animate-fade-up">
          {project.data.thumbnail && (
            <Image src={project.data.thumbnail} alt={project.data.title} class="w-full h-40 object-cover rounded-md mb-4 border border-border" loading="lazy" width={800} height={320} />
          )}
          <div class="flex items-center justify-between mb-4">
            <span class={`px-2 py-1 rounded text-fluid-xs font-sans font-medium border ${
              project.data.status === 'active' ? 'bg-accent-subtle text-accent border-accent/20' :
              project.data.status === 'wip' ? 'bg-yellow-500/10 text-yellow-600 border-yellow-500/20 dark:text-yellow-400' :
              'bg-text-muted/10 text-text-muted border-text-muted/20'
            }`}>
              {projectLabels.status[project.data.status]}
            </span>
            <span class="text-fluid-xs font-sans text-text-muted">
              {project.data.startDate.getFullYear()}
              {project.data.endDate ? ` - ${project.data.endDate.getFullYear()}` : ''}
            </span>
          </div>
          
          <h2 class="font-sans text-xl font-semibold text-text-primary group-hover:text-accent transition-colors mb-2 tracking-tight">
            {project.data.title}
          </h2>
          
          <p class="font-sans text-base text-text-secondary leading-relaxed mb-6 flex-1">
            {project.data.description}
          </p>
          
          <div class="flex flex-wrap gap-2 mb-6">
            {project.data.techStack.map(tech => (
              <span class="px-2 py-1 rounded text-sm font-sans text-text-secondary bg-elevated border border-border">
                {tech}
              </span>
            ))}
          </div>
          
          <div class="flex gap-4 pt-4 border-t border-border">
            {project.data.link && (
              <a href={project.data.link} target="_blank" class="font-sans text-base text-accent hover:text-accent-hover transition-colors">{projectLabels.linkText}</a>
            )}
            {project.data.github && (
              <a href={project.data.github} target="_blank" class="font-sans text-base text-text-secondary hover:text-text-primary transition-colors">{projectLabels.githubText}</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</Base>
