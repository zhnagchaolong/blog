---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/layout/PageHeader.astro';
import { formatDate } from '@/utils/date';
import { statusConfig } from '@/config/labels';
import type { StatusKey } from '@/config/labels';
import { pageMeta } from '@/config/site';

const entries = await getCollection('now');
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// content-type 集合需要 render() 后才能获取 Content 组件
const renderedEntries = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  })
);

const latest = renderedEntries[0];
const history = renderedEntries.slice(1);

function energyDots(energy: number) {
  return Array.from({ length: 10 }, (_, i) => i < energy);
}
---

<Base title={pageMeta.now.title} description={pageMeta.now.description}>
  <div class="max-w-prose-lg mx-auto">
    <PageHeader
      label={`${pageMeta.now.labelPrefix} / ${String(entries.length).padStart(3, '0')}`}
      title={pageMeta.now.heading}
      subtitle={pageMeta.now.subtitle}
    />

    {/* 当前状态 — 大卡片 */}
    {latest && (
      <div class="mb-16 animate-fade-up">
        <span class="font-mono text-[10px] text-text-muted/50 uppercase tracking-widest mb-4 block">Current Status</span>
        <div class="p-8 rounded-md bg-surface border border-border/50 ">
          <div class="flex items-center gap-3 mb-6">
            <span
              class="w-2.5 h-2.5 rounded-full animate-pulse"
              style={`background-color: ${statusConfig[latest.entry.data.status].color}; box-shadow: 0 0 8px ${statusConfig[latest.entry.data.status].color}40;`}
            ></span>
            <span class="font-mono text-xs" style={`color: ${statusConfig[latest.entry.data.status].color}`}>
              {statusConfig[latest.entry.data.status].label}
            </span>
            <span class="text-text-muted/20">·</span>
            <time class="font-mono text-[11px] text-text-muted" datetime={latest.entry.data.date.toISOString()}>
              {formatDate(latest.entry.data.date)}
            </time>
            {latest.entry.data.mood && (
              <>
                <span class="text-text-muted/20">·</span>
                <span class="font-mono text-[11px] text-text-muted/60">{latest.entry.data.mood}</span>
              </>
            )}
          </div>

          <div class="prose-zen font-sans text-lg text-text-primary leading-[1.8] mb-6">
            <latest.Content />
          </div>

          <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-border/40">
            {latest.entry.data.energy && (
              <div class="flex items-center gap-1">
                <span class="font-mono text-[10px] text-text-muted/40 mr-1">Energy</span>
                {energyDots(latest.entry.data.energy).map((on, i) => (
                  <span class={`w-1 h-3 rounded-sm ${on ? 'bg-accent' : 'bg-border'}`}></span>
                ))}
              </div>
            )}
            {latest.entry.data.tags.length > 0 && (
              <div class="flex gap-2">
                {latest.entry.data.tags.map(tag => (
                  <span class="font-mono text-[10px] text-text-muted/50">[ {tag} ]</span>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    )}

    {/* 历史状态流 */}
    {history.length > 0 && (
      <div class="animate-fade-up">
        <span class="font-mono text-[10px] text-text-muted/50 uppercase tracking-widest mb-6 block">History</span>
        <div class="space-y-4">
          {history.map(({ entry: e, Content: C }) => (
            <div class="p-5 rounded-md bg-surface/60 border border-border/40 transition-all duration-200 hover:bg-surface hover:border-border/70">
              <div class="flex items-center gap-3 mb-3">
                <span
                  class="w-2 h-2 rounded-full shrink-0"
                  style={`background-color: ${statusConfig[e.data.status].color};`}
                ></span>
                <span class="font-mono text-[11px]" style={`color: ${statusConfig[e.data.status].color}99`}>
                  {statusConfig[e.data.status].label}
                </span>
                <span class="text-text-muted/20">·</span>
                <time class="font-mono text-[10px] text-text-muted/50" datetime={e.data.date.toISOString()}>
                  {formatDate(e.data.date)}
                </time>
              </div>
              <div class="font-sans text-base text-text-secondary leading-relaxed line-clamp-2">
                <C />
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</Base>
