---
import Base from '@/layouts/Base.astro';
import { pageMeta, aboutConfig } from '@/config/site';

const techStack = aboutConfig.cards.techStack.items;
const setup = aboutConfig.cards.setup.items;
---

<Base title={pageMeta.about.title} description={pageMeta.about.description}>
  <div class="max-w-prose-lg mx-auto">
    <header class="mb-12 animate-fade-up">
      <h1 class="font-sans text-fluid-2xl font-bold text-text-primary mb-4 tracking-tight">{pageMeta.about.heading}</h1>
      <p class="font-sans text-fluid-base text-text-secondary">{pageMeta.about.subtitle}</p>
    </header>

    {/* Bento Grid */}
    <div class="grid md:grid-cols-3 gap-4 animate-fade-up">

      {/* Brief — 价值观宣述（左上大卡片） */}
      <div class="md:col-span-2 p-8 rounded-md bg-surface border border-border/50 transition-all duration-300 flex flex-col justify-between min-h-[280px]">
        <div>
          <span class="font-mono text-[10px] text-text-muted/50 uppercase tracking-widest">{aboutConfig.cards.brief.label}</span>
          <h2 class="font-sans text-2xl font-bold text-text-primary mt-4 leading-[1.3]">
            {aboutConfig.cards.brief.heading}          </h2>
        </div>
        <p class="font-sans text-base text-text-secondary mt-6 leading-relaxed max-w-md">
          {aboutConfig.cards.brief.description}        </p>
      </div>

      {/* Tech Stack — 工具图标（右上卡片） */}
      <div class="p-8 rounded-md bg-surface border border-border/50 transition-all duration-300 ">
        <span class="font-mono text-[10px] text-text-muted/50 uppercase tracking-widest">{aboutConfig.cards.techStack.label}</span>
        <div class="mt-6 space-y-3">
          {techStack.map(tool => (
            <div class="flex items-center justify-between group">
              <span class="font-sans text-base text-text-primary group-hover:text-accent transition-colors duration-300">
                {tool.name}
              </span>
              <span class="font-mono text-xs text-text-muted/40">
                {tool.category}
              </span>
            </div>
          ))}
        </div>
      </div>

      {/* Setup — 硬核配置（下方大卡片） */}
      <div class="md:col-span-2 p-8 rounded-md bg-surface border border-border/50 transition-all duration-300 ">
        <span class="font-mono text-[10px] text-text-muted/50 uppercase tracking-widest">{aboutConfig.cards.setup.label}</span>
        <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {setup.map(item => (
            <div class="p-4 rounded-md bg-elevated/50 border border-border/30">
              <span class="font-mono text-xs text-text-muted/40 block mb-1">{item.item}</span>
              <span class="font-sans text-base text-text-primary">{item.detail}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Contact — 联系（右下小卡片） */}
      <div class="p-8 rounded-md bg-surface border border-border/50 transition-all duration-300 flex flex-col justify-center">
        <span class="font-mono text-[10px] text-text-muted/50 uppercase tracking-widest">{aboutConfig.cards.contact.label}</span>
        <p class="font-sans text-base text-text-secondary mt-4 leading-relaxed">
          {aboutConfig.cards.contact.description}        </p>
        <a
          href="mailto:hello@example.com"
          class="mt-4 inline-flex items-center gap-2 text-sm font-sans text-accent hover:text-accent-hover transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {aboutConfig.cards.contact.buttonText}        </a>
      </div>

    </div>

    {/* 底部 quote */}
    <div class="mt-12 text-center animate-fade-up">
      <blockquote class="font-sans italic font-bold text-text-secondary text-xl">
        <p>{aboutConfig.quote}</p>
      </blockquote>
    </div>
  </div>
</Base>
