---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/layout/PageHeader.astro';
import BackLink from '@/components/layout/BackLink.astro';
import { formatDate } from '@/utils/date';
import { getReadingTime } from '@/utils/readingTime';
import { categoryLabels } from '@/config/labels';
import { pageMeta } from '@/config/site';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  allPosts.forEach(post => post.data.tags.forEach(tag => tagSet.add(tag)));

  return Array.from(tagSet).map(tag => {
    const taggedPosts = allPosts
      .filter(post => post.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return {
      params: { tag },
      props: { tag, taggedPosts },
    };
  });
}

const { tag, taggedPosts } = Astro.props;

---

<Base title={`${pageMeta.tags.title}：${tag}`} description={`包含「${tag}」标签的所有文章`}>
  <div class="max-w-prose-lg mx-auto">
    <BackLink href={import.meta.env.BASE_URL + '/tags'} />

    <PageHeader
      label={`${pageMeta.tagDetail.labelPrefix} / ${String(taggedPosts.length).padStart(3, '0')}`}
      title={tag}
      subtitle={pageMeta.tagDetail.subtitle.replace('{count}', String(taggedPosts.length))}
    />

    <div class="space-y-14 pb-24">
      {taggedPosts.map(post => (
        <a
          href={`${import.meta.env.BASE_URL}/posts/${post.slug}/`}
          class="group block"
        >
          <div class="flex items-start gap-6 md:gap-10">
            <!-- 日期 -->
            <time
              class="font-mono text-[11px] text-text-muted w-12 shrink-0 pt-1.5 tabular-nums"
              datetime={post.data.pubDate.toISOString()}
            >
              {post.data.pubDate.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
            </time>

            <!-- 内容 -->
            <div class="flex-1 min-w-0">
              <!-- 标题：hover 下划线 -->
              <span class="relative inline-block">
                <span class="font-sans text-lg font-normal text-text-primary group-hover:text-accent transition-colors duration-300 leading-snug">
                  {post.data.title}
                </span>
                <span class="absolute left-0 -bottom-0.5 h-px bg-accent transition-all duration-300 w-0 group-hover:w-full"></span>
              </span>

              <!-- 摘要 -->
              <p class="font-sans text-base text-text-secondary mt-2.5 leading-relaxed max-w-xl">
                {post.data.description}
              </p>

              <!-- 元信息 -->
              <div class="flex items-center gap-4 mt-3">
                <span class="font-mono text-xs text-text-muted">
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                {post.data.series && (
                  <span class="font-mono text-xs text-text-muted">
                    {post.data.series}
                  </span>
                )}
                <span class="font-mono text-xs text-text-muted">
                  {getReadingTime(post.body)}
                </span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
